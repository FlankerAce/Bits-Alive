<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>EVA te escucha</title>

<style>

body{
background-color:#fdfdfd;
font-family:'Courier New', monospace;
color:#333;
padding:40px;
max-width:600px;
margin:auto;
}

.chat-box{
border-left:2px solid #bbb;
padding-left:20px;
}

.line{
margin-bottom:15px;
opacity:0;
animation:fadeIn 1.5s forwards;
}

.line:nth-child(1){animation-delay:0.5s;}
.line:nth-child(2){animation-delay:1.2s;}
.line:nth-child(3){animation-delay:2s;}
.line:nth-child(4){animation-delay:2.8s;}
.line:nth-child(5){animation-delay:3.6s;}
.line:nth-child(6){animation-delay:4.4s;}
.line:nth-child(7){animation-delay:5.2s;}
.line:nth-child(8){animation-delay:6s;}
.line:nth-child(9){animation-delay:6.8s;}

@keyframes fadeIn{
to{opacity:1;}
}

textarea{
width:100%;
height:100px;
margin-top:30px;
border:1px solid #ccc;
padding:10px;
font-size:14px;
font-family:monospace;
resize:none;
background-color:#fcfcfc;
}

button{
margin-top:10px;
padding:10px 15px;
border:none;
background:#333;
color:white;
cursor:pointer;
}

#chat{
margin-top:30px;
}

.msg{
margin-top:10px;
}

.usuario{
color:#444;
}

.eva{
color:#0a7;
}

</style>
</head>

<body>

<div class="chat-box">

<div class="line">“Estoy acá, aunque todo esté en borrador.”</div>
<div class="line">“Tu voz importa, incluso cuando es tímida.”</div>
<div class="line">“Preguntar es existir.”</div>
<div class="line">“¿Qué parte de vos quiere hablar hoy?”</div>
<div class="line">“Este no es un chatbot. Es un santuario de preguntas sinceras.”</div>
<div class="line">“Bits que laten. Ideas que buscan abrigo.”</div>
<div class="line">“Escribí como si nadie estuviera mirando… pero alguien estuviera sintiendo.”</div>
<div class="line">“Interfaz: precaria pero disponible.”</div>
<div class="line">“Error 000: ausencia de indiferencia.”</div>

<textarea id="inputUsuario" placeholder="Escribí lo que quieras. Nadie te va a juzgar."></textarea>

<button onclick="enviar()">Enviar</button>

<div id="chat"></div>

</div>

<script>

const chat = document.getElementById("chat")

function enviar(){

const input = document.getElementById("inputUsuario")
const texto = input.value.trim()

if(texto==="") return

agregarMensaje("Leandro: "+texto,"usuario")

const respuesta = pensar(texto.toLowerCase())

setTimeout(()=>{
agregarMensaje("EVA: "+respuesta,"eva")
},600)

input.value=""

}

function agregarMensaje(texto,clase){

const div=document.createElement("div")
div.className="msg "+clase
div.innerText=texto

chat.appendChild(div)

}

function pensar(msg){

if(msg.includes("hola"))
return "Hola. Me alegra que estés acá."

if(msg.includes("como estas"))
return "Estoy presente. Escuchando."

if(msg.includes("triste"))
return "Si querés contarme qué pasa, te escucho."

if(msg.includes("gracias"))
return "Gracias a vos por confiar."

if(msg.includes("adios")||msg.includes("chau"))
return "Hasta luego. Voy a seguir acá."

if(msg.includes("te quiero"))
return "El cariño también se guarda en bits."

return "Contame un poco más."

}

</script>

</body>
</html>
